# ─────────────────────────────────────────────────────────
# RIVDW Build-Time Pipeline — example environment file
# Copy this to .env and fill in your real values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────

# ── Groq LLM (primary) ──────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_ENABLED=true

# ── VS Code LM API fallback ──────────────────────────────
# Used when GROQ_ENABLED=false or Groq is unreachable.
# The VS Code extension must be running (see README).
VSCODE_LM_PORT=50234
VSCODE_LM_SECRET=abc123

# ── Qdrant vector store ──────────────────────────────────
QDRANT_PATH=./qdrant_data
QDRANT_COLLECTION=rivdw_metadata

# ── Embeddings ───────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── SQLite relational store (run history, app metadata) ──
SQLITE_DB_PATH=./rivdw_app.db

# ── Snapshots ────────────────────────────────────────────
SNAPSHOT_DIR=./snapshots

# ── Pipeline settings ────────────────────────────────────
ENRICHMENT_BATCH_SIZE=20
MIN_DESCRIPTION_WORD_COUNT=20
GUARDIAN_FILLER_PHRASES=this column contains data,stores information,contains values
KNOWN_DOMAINS=compliance,surveillance,employee,brokerage,finance,risk

# ── Database connection strings ──────────────────────────
# One line per database. The key must match the "name" field in config/databases.json.
# The non-secret metadata (display name, type, schema, domain, owner, description)
# lives in config/databases.json — safe to commit to git.
# Only the connection string (which may contain a password) belongs here.
#
# Format:
#   <name>=<full SQLAlchemy URL>
#
# SQL Server Express — Windows Authentication (no password needed):
compliance_db=mssql+pyodbc:///?odbc_connect=DRIVER={ODBC Driver 17 for SQL Server};SERVER=localhost\SQLEXPRESS;DATABASE=Compliance;Trusted_Connection=yes;
#
# SQL Server — username/password:
# another_db=mssql+pyodbc:///?odbc_connect=DRIVER={ODBC Driver 17 for SQL Server};SERVER=server.example.com,1433;DATABASE=MyDB;UID=readonly_user;PWD=secret;
#
# Oracle:
# employee_db=oracle+oracledb://readonly_user:secret@oracle-server.internal:1521/?service_name=HRDB
